<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:Boolean x:Key="Theme.IsThemeDictionary">True</sys:Boolean>
    <sys:Boolean x:Key="Theme.IsLight">True</sys:Boolean>

    <SolidColorBrush x:Key="Brush.WindowBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.SidebarBackground" Color="#F3F3F3" />
    <SolidColorBrush x:Key="Brush.ToolbarBackground" Color="#ECECEC" />
    <SolidColorBrush x:Key="Brush.Border" Color="#D0D0D0" />
    <SolidColorBrush x:Key="Brush.PrimaryText" Color="#1F1F1F" />
    <SolidColorBrush x:Key="Brush.SecondaryText" Color="#5A5A5A" />
    <SolidColorBrush x:Key="Brush.ControlBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.ControlBorder" Color="#C8C8C8" />
    <SolidColorBrush x:Key="Brush.ControlHover" Color="#E5E5E5" />
    <SolidColorBrush x:Key="Brush.ControlPressed" Color="#D5D5D5" />
    <SolidColorBrush x:Key="Brush.ListHover" Color="#E8E8E8" />
    <SolidColorBrush x:Key="Brush.ListSelected" Color="#CCE4F7" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#F8F8F8" />
    <SolidColorBrush x:Key="Brush.MenuHighlight" Color="#CCE4F7" />
    <SolidColorBrush x:Key="Brush.MenuHighlightText" Color="#1F1F1F" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#007ACC" />
    <SolidColorBrush x:Key="Brush.SelectionBrush" Color="#ADD6FF" />
    <SolidColorBrush x:Key="Brush.SaveStateDefault" Color="#157F5F" />

    <SolidColorBrush x:Key="Brush.EditorBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.EditorForeground" Color="#1F1F1F" />
    <SolidColorBrush x:Key="Brush.EditorLineNumber" Color="#909090" />
    <SolidColorBrush x:Key="Brush.EditorSelection" Color="#ADD6FF" />

</ResourceDictionary>
