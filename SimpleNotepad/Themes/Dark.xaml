<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:Boolean x:Key="Theme.IsThemeDictionary">True</sys:Boolean>
    <sys:Boolean x:Key="Theme.IsLight">False</sys:Boolean>

    <SolidColorBrush x:Key="Brush.WindowBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="Brush.SidebarBackground" Color="#252526" />
    <SolidColorBrush x:Key="Brush.ToolbarBackground" Color="#2D2D30" />
    <SolidColorBrush x:Key="Brush.Border" Color="#3C3C3C" />
    <SolidColorBrush x:Key="Brush.PrimaryText" Color="#D4D4D4" />
    <SolidColorBrush x:Key="Brush.SecondaryText" Color="#9DA5B4" />
    <SolidColorBrush x:Key="Brush.ControlBackground" Color="#3C3C3C" />
    <SolidColorBrush x:Key="Brush.ControlBorder" Color="#555555" />
    <SolidColorBrush x:Key="Brush.ControlHover" Color="#505050" />
    <SolidColorBrush x:Key="Brush.ControlPressed" Color="#2A2A2A" />
    <SolidColorBrush x:Key="Brush.ListHover" Color="#2A2D2E" />
    <SolidColorBrush x:Key="Brush.ListSelected" Color="#094771" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#2D2D30" />
    <SolidColorBrush x:Key="Brush.MenuHighlight" Color="#094771" />
    <SolidColorBrush x:Key="Brush.MenuHighlightText" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#007ACC" />
    <SolidColorBrush x:Key="Brush.SelectionBrush" Color="#264F78" />
    <SolidColorBrush x:Key="Brush.SaveStateDefault" Color="#4EC9B0" />

    <SolidColorBrush x:Key="Brush.EditorBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="Brush.EditorForeground" Color="#D4D4D4" />
    <SolidColorBrush x:Key="Brush.EditorLineNumber" Color="#858585" />
    <SolidColorBrush x:Key="Brush.EditorSelection" Color="#264F78" />

</ResourceDictionary>
