<Window x:Class="SimpleNotepad.AiSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Settings (Azure OpenAI)"
        Height="420"
        Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.WindowBackground}"
        FontFamily="Segoe UI"
        FontSize="13">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Margin="0,0,0,14"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Brush.SecondaryText}"
                   Text="Enter your Azure OpenAI details. The API key is stored encrypted on this device (Windows DPAPI) and never written in plain text. Selected text is sent to Azure OpenAI when you rewrite." />

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Margin="0,0,10,10" VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.PrimaryText}"
                   Text="Endpoint" />
        <TextBox x:Name="EndpointBox" Grid.Row="1" Grid.Column="1"
                 Margin="0,0,0,10" Padding="6,4"
                 ToolTip="e.g. https://my-resource.openai.azure.com/" />

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Margin="0,0,10,10" VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.PrimaryText}"
                   Text="Deployment" />
        <TextBox x:Name="DeploymentBox" Grid.Row="2" Grid.Column="1"
                 Margin="0,0,0,10" Padding="6,4"
                 ToolTip="The chat model deployment name, e.g. gpt-4o" />

        <TextBlock Grid.Row="3" Grid.Column="0"
                   Margin="0,0,10,10" VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.PrimaryText}"
                   Text="API key" />
        <PasswordBox x:Name="ApiKeyBox" Grid.Row="3" Grid.Column="1"
                     Margin="0,0,0,10" Padding="6,4" />

        <TextBlock Grid.Row="4" Grid.Column="0"
                   Margin="0,0,10,10" VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.PrimaryText}"
                   Text="Temperature" />
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Slider x:Name="TemperatureSlider" Width="220" Minimum="0" Maximum="2"
                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center" />
            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource Brush.PrimaryText}"
                       Text="{Binding ElementName=TemperatureSlider, Path=Value, StringFormat=F1}" />
        </StackPanel>

        <TextBlock x:Name="StatusText" Grid.Row="5" Grid.ColumnSpan="2"
                   Margin="0,4,0,0" TextWrapping="Wrap"
                   Foreground="{DynamicResource Brush.SecondaryText}" />

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="TestButton" Content="Test connection" Padding="12,5"
                    Margin="0,0,8,0" Click="TestButton_Click" />
            <Button x:Name="SaveButton" Content="Save" Padding="16,5"
                    Margin="0,0,8,0" IsDefault="True" Click="SaveButton_Click" />
            <Button Content="Cancel" Padding="12,5" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
