<Window x:Class="SimpleNotepad.RewritePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Rewrite"
        Icon="app.ico"
        Height="560"
        Width="820"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.WindowBackground}"
        FontFamily="Segoe UI"
        FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="True">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource Brush.PrimaryText}"
                       Text="Instruction" />
            <Button x:Name="RegenerateButton" DockPanel.Dock="Right" Margin="8,0,0,0"
                    Padding="12,5" Content="Rewrite" Click="RegenerateButton_Click" />
            <TextBox x:Name="InstructionBox" Padding="6,4"
                     ToolTip="Optional, e.g. 'make concise', 'fix grammar', 'formal tone'. Leave empty for a general rewrite." />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,4"
                           Foreground="{DynamicResource Brush.SecondaryText}"
                           Text="Original" />
                <TextBox x:Name="OriginalBox" IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" Padding="6" />
            </DockPanel>

            <DockPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,4"
                           Foreground="{DynamicResource Brush.SecondaryText}"
                           Text="Suggestion (editable)" />
                <TextBox x:Name="SuggestionBox"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" Padding="6" />
            </DockPanel>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="2" Margin="0,10,0,0" TextWrapping="Wrap"
                   Foreground="{DynamicResource Brush.SecondaryText}" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelCallButton" Content="Stop" Padding="12,5" Margin="0,0,8,0"
                    Visibility="Collapsed" Click="CancelCallButton_Click" />
            <Button x:Name="ReplaceButton" Content="Replace" Padding="16,5" Margin="0,0,8,0"
                    IsDefault="True" IsEnabled="False" Click="ReplaceButton_Click" />
            <Button Content="Cancel" Padding="12,5" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
