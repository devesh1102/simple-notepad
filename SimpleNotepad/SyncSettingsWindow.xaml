<Window x:Class="SimpleNotepad.SyncSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sync Settings (Azure Blob Storage)"
        Icon="app.ico"
        Height="430"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.WindowBackground}"
        FontFamily="Segoe UI"
        FontSize="13">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Margin="0,0,0,14"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Brush.SecondaryText}"
                   Text="Sync your own sessions across your devices through a private Azure Blob container. The connection string grants full access to that storage account — use a dedicated account. It is stored encrypted on this device (Windows DPAPI). Sessions from other devices appear read-only; use 'Duplicate to edit' to fork them." />

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Margin="0,0,10,10" VerticalAlignment="Top"
                   Foreground="{DynamicResource Brush.PrimaryText}"
                   Text="Connection string" />
        <TextBox x:Name="ConnectionStringBox" Grid.Row="1" Grid.Column="1"
                 Margin="0,0,0,10" Padding="6,4"
                 Height="56" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 ToolTip="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net" />

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Margin="0,0,10,10" VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.PrimaryText}"
                   Text="Container" />
        <TextBox x:Name="ContainerBox" Grid.Row="2" Grid.Column="1"
                 Margin="0,0,0,10" Padding="6,4"
                 ToolTip="Blob container name (lowercase). Default: simplenotepad" />

        <TextBlock Grid.Row="3" Grid.Column="0"
                   Margin="0,0,10,10" VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.PrimaryText}"
                   Text="Device name" />
        <TextBox x:Name="DeviceNameBox" Grid.Row="3" Grid.Column="1"
                 Margin="0,0,0,10" Padding="6,4"
                 ToolTip="How this device is labelled on your other devices." />

        <TextBlock Grid.Row="4" Grid.Column="0"
                   Margin="0,0,10,10" VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.PrimaryText}"
                   Text="Device color" />
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Border x:Name="ColorSwatch" Width="22" Height="22" CornerRadius="3"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" />
            <TextBox x:Name="DeviceColorBox" Width="110" Margin="10,0,0,0" Padding="6,4"
                     TextChanged="DeviceColorBox_TextChanged"
                     ToolTip="Hex color used to tint this device's notes, e.g. #4EC9B0" />
        </StackPanel>

        <TextBlock x:Name="StatusText" Grid.Row="5" Grid.ColumnSpan="2"
                   Margin="0,4,0,0" TextWrapping="Wrap" VerticalAlignment="Top"
                   Foreground="{DynamicResource Brush.SecondaryText}" />

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="TestButton" Content="Test connection" Padding="12,5"
                    Margin="0,0,8,0" Click="TestButton_Click" />
            <Button x:Name="SaveButton" Content="Save" Padding="16,5"
                    Margin="0,0,8,0" IsDefault="True" Click="SaveButton_Click" />
            <Button Content="Cancel" Padding="12,5" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
