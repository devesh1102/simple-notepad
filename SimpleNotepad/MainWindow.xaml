<Window x:Class="SimpleNotepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleNotepad"
        mc:Ignorable="d"
        Title="Simple Notepad"
        Icon="app.ico"
        Height="720"
        Width="1100"
        MinHeight="480"
        MinWidth="760">
    <Window.Resources>
        <!-- Button style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.ControlHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.ControlPressed}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource Brush.SelectionBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- ListBoxItem style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4"
                                Margin="0,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.ListHover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.ListSelected}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ContextMenu style -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource Brush.MenuBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
        </Style>

        <!-- MenuItem style -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="Background" Value="{DynamicResource Brush.MenuBackground}" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.MenuHighlight}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.MenuHighlight}" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.MenuHighlightText}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Separator style -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource Brush.Border}" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource Brush.WindowBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="280" MinWidth="220" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" MinWidth="420" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource Brush.SidebarBackground}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="SyncSettingsButton"
                                Padding="6,3" Margin="0,0,6,0"
                                Content="⚙"
                                ToolTip="Configure cloud sync"
                                Click="SyncSettingsButton_Click" />
                        <Button x:Name="SyncButton"
                                Padding="8,3"
                                Content="Sync"
                                ToolTip="Sync sessions across your devices"
                                Click="SyncButton_Click" />
                    </StackPanel>
                    <TextBlock Text="Sessions"
                               FontSize="20"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.PrimaryText}" />
                </DockPanel>

                <StackPanel Grid.Row="1" Margin="0,14,0,12">
                    <Button x:Name="NewSessionButton"
                            Padding="10,7"
                            HorizontalContentAlignment="Left"
                            Content="+ New Session"
                            Click="NewSessionButton_Click" />
                    <TextBlock x:Name="SyncStatusText"
                               Margin="2,6,0,0"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               Text="Sync not configured" />
                </StackPanel>

                <TextBox x:Name="SessionSearchBox"
                         Grid.Row="2"
                         Margin="0,0,0,12"
                         Padding="8,6"
                         ToolTip="Search sessions"
                         TextChanged="SessionSearchBox_TextChanged" />

                <ListBox x:Name="SessionsList"
                         Grid.Row="3"
                         BorderThickness="0"
                         Background="Transparent"
                         PreviewMouseRightButtonDown="SessionsList_PreviewMouseRightButtonDown"
                         ContextMenuOpening="SessionsList_ContextMenuOpening"
                         SelectionChanged="SessionsList_SelectionChanged">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="DuplicateToEditMenuItem" Header="Duplicate to edit" Click="DuplicateToEdit_Click" />
                            <MenuItem x:Name="RenameSessionMenuItem" Header="Rename" Click="RenameSession_Click" />
                            <MenuItem x:Name="DeleteSessionMenuItem" Header="Delete" Click="DeleteSession_Click" />
                            <Separator />
                            <MenuItem x:Name="PinSessionMenuItem" Header="Pin/Unpin" Click="PinSession_Click" />
                            <MenuItem Header="Export…" Click="ExportSession_Click" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="3" CornerRadius="2"
                                        Margin="0,0,6,0"
                                        Background="{Binding AccentBrush}" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.PrimaryText}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,3,0,0"
                                               Text="{Binding OriginLabel}"
                                               Visibility="{Binding OriginVisibility}"
                                               FontSize="12"
                                               Foreground="{Binding AccentBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,3,0,0"
                                               Text="{Binding ExpiryText}"
                                               FontSize="12"
                                               Foreground="{DynamicResource Brush.SecondaryText}" />
                                    <TextBlock Margin="0,3,0,0"
                                               Text="{Binding LastModifiedText}"
                                               FontSize="12"
                                               Foreground="{DynamicResource Brush.SecondaryText}" />
                                    <TextBlock Margin="0,3,0,0"
                                               Text="{Binding Preview}"
                                               FontSize="12"
                                               Foreground="{DynamicResource Brush.SecondaryText}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="EmptyStateText"
                           Grid.Row="3"
                           Margin="16,24"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           VerticalAlignment="Top"
                           FontSize="13"
                           Foreground="{DynamicResource Brush.SecondaryText}"
                           Visibility="Collapsed"
                           Text="No sessions yet. Click &quot;New Session&quot; to get started." />
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource Brush.Border}" />

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="16,12"
                    Background="{DynamicResource Brush.ToolbarBackground}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right"
                               Orientation="Horizontal"
                               VerticalAlignment="Center">
                        <Button x:Name="FormatJsonButton"
                               Margin="0,0,8,0"
                               Padding="8,3"
                               Content="Format JSON"
                               ToolTip="Format selected JSON or the full note (Ctrl+Shift+F)"
                               Click="FormatJsonButton_Click" />
                        <Button x:Name="MinifyJsonButton"
                               Margin="0,0,8,0"
                               Padding="8,3"
                               Content="Minify"
                               ToolTip="Minify selected JSON or the full note"
                               Click="MinifyJsonButton_Click" />
                        <Button x:Name="OpenJsonInVsCodeButton"
                               Margin="0,0,12,0"
                               Padding="8,3"
                               Content="VS Code"
                               ToolTip="Open selected JSON or the full note in Visual Studio Code"
                               Click="OpenJsonInVsCodeButton_Click" />
                        <Button x:Name="RewriteButton"
                               Margin="0,0,8,0"
                               Padding="8,3"
                               Content="Rewrite"
                               ToolTip="Rewrite the selected text with AI"
                               Click="RewriteButton_Click" />
                        <Button x:Name="AiSettingsButton"
                               Margin="0,0,12,0"
                               Padding="8,3"
                               Content="AI…"
                               ToolTip="Configure Azure OpenAI for AI features"
                               Click="AiSettingsButton_Click" />
                        <Button x:Name="WordWrapButton"
                               Margin="0,0,12,0"
                               Padding="8,3"
                               Content="Wrap: On"
                               ToolTip="Toggle word wrap"
                               Click="WordWrapButton_Click" />
                        <Button x:Name="ThemeButton"
                               Margin="0,0,12,0"
                               Padding="8,3"
                               Content="Theme: Dark"
                               ToolTip="Switch theme (System / Light / Dark)"
                               Click="ThemeButton_Click" />
                        <TextBlock x:Name="SaveStateText"
                                  Text="Saved"
                                  Foreground="{DynamicResource Brush.SaveStateDefault}"
                                  VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox x:Name="SessionTitleBox"
                             Text="Untitled"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.PrimaryText}"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalAlignment="Center"
                             TextChanged="SessionTitleBox_TextChanged" />
                </DockPanel>
            </Border>

            <Border x:Name="FindReplaceBar"
                    Grid.Row="1"
                    Padding="10"
                    Background="{DynamicResource Brush.ToolbarBackground}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,0,1"
                    Visibility="Collapsed">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="Find"
                               Foreground="{DynamicResource Brush.PrimaryText}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBox x:Name="FindTextBox"
                             Width="180"
                             Margin="0,0,10,0"
                             Padding="6,4"
                             TextChanged="FindTextBox_TextChanged"
                             PreviewKeyDown="FindReplaceTextBox_PreviewKeyDown" />
                    <TextBlock Text="Replace"
                               Foreground="{DynamicResource Brush.PrimaryText}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBox x:Name="ReplaceTextBox"
                             Width="180"
                             Margin="0,0,10,0"
                             Padding="6,4"
                             PreviewKeyDown="FindReplaceTextBox_PreviewKeyDown" />
                    <Button Content="Prev"
                            Margin="0,0,6,0"
                            Click="FindPreviousButton_Click" />
                    <Button Content="Next"
                            Margin="0,0,6,0"
                            Click="FindNextButton_Click" />
                    <Button Content="Replace"
                            Margin="0,0,6,0"
                            Click="ReplaceButton_Click" />
                    <Button Content="All"
                            Margin="0,0,10,0"
                            Click="ReplaceAllButton_Click" />
                    <CheckBox x:Name="MatchCaseCheckBox"
                             Content="Case"
                             Margin="0,0,10,0"
                             Checked="FindOptionsChanged"
                             Unchecked="FindOptionsChanged" />
                    <CheckBox x:Name="WholeWordCheckBox"
                             Content="Whole word"
                             Margin="0,0,10,0"
                             Checked="FindOptionsChanged"
                             Unchecked="FindOptionsChanged" />
                    <TextBlock x:Name="MatchCountText"
                              Foreground="{DynamicResource Brush.SecondaryText}"
                              VerticalAlignment="Center"
                              Margin="0,0,10,0"
                              Text="0 matches" />
                    <Button Content="x"
                            Click="CloseFindReplaceButton_Click" />
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="16"
                    Background="{DynamicResource Brush.EditorBackground}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
                <avalonEdit:TextEditor x:Name="Editor"
                                       ShowLineNumbers="True"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       Padding="8"
                                       WordWrap="True"
                                       Background="{DynamicResource Brush.EditorBackground}"
                                       Foreground="{DynamicResource Brush.EditorForeground}"
                                       AllowDrop="True"
                                       PreviewDragOver="Editor_PreviewDragOver"
                                       PreviewDrop="Editor_PreviewDrop"
                                       ContextMenuOpening="Editor_ContextMenuOpening"
                                       TextChanged="Editor_TextChanged">
                    <avalonEdit:TextEditor.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="SendToPowerShellMenuItem"
                                      Header="Send to Linked PowerShell"
                                      Click="SendToPowerShellMenuItem_Click" />
                            <MenuItem x:Name="SendToAdminPowerShellMenuItem"
                                      Header="Send to Linked PowerShell as Admin"
                                      Click="SendToAdminPowerShellMenuItem_Click" />
                            <Separator />
                            <MenuItem x:Name="RestartNormalPowerShellMenuItem"
                                      Header="Restart Linked PowerShell"
                                      Click="RestartNormalPowerShellMenuItem_Click" />
                            <MenuItem x:Name="RestartAdminPowerShellMenuItem"
                                      Header="Restart Admin PowerShell"
                                      Click="RestartAdminPowerShellMenuItem_Click" />
                            <MenuItem x:Name="StopNormalPowerShellMenuItem"
                                      Header="Stop Linked PowerShell"
                                      Click="StopNormalPowerShellMenuItem_Click" />
                            <MenuItem x:Name="StopAdminPowerShellMenuItem"
                                      Header="Stop Admin PowerShell"
                                      Click="StopAdminPowerShellMenuItem_Click" />
                            <Separator />
                            <MenuItem x:Name="FormatJsonMenuItem"
                                      Header="Format JSON"
                                      Click="FormatJsonButton_Click" />
                            <MenuItem x:Name="MinifyJsonMenuItem"
                                      Header="Minify JSON"
                                      Click="MinifyJsonButton_Click" />
                            <MenuItem x:Name="OpenJsonInVsCodeMenuItem"
                                      Header="Open JSON in VS Code"
                                      Click="OpenJsonInVsCodeButton_Click" />
                            <Separator />
                            <MenuItem x:Name="RewriteMenuItem"
                                      Header="Rewrite with AI"
                                      Click="RewriteButton_Click" />
                            <MenuItem x:Name="GenerateTitleMenuItem"
                                      Header="Generate title with AI"
                                      Click="GenerateTitleMenuItem_Click" />
                        </ContextMenu>
                    </avalonEdit:TextEditor.ContextMenu>
                </avalonEdit:TextEditor>
            </Border>

            <Border Grid.Row="3"
                    Padding="12,7"
                    Background="{DynamicResource Brush.ToolbarBackground}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,1,0,0">
                <DockPanel LastChildFill="True">
                    <TextBlock x:Name="LinkedPowerShellStatusText"
                               DockPanel.Dock="Right"
                               Text="PS: normal disconnected, admin disconnected"
                               Foreground="{DynamicResource Brush.SecondaryText}" />
                    <TextBlock x:Name="StatusText"
                               Text="Ln 1, Col 1 | 0 chars | Saved"
                               Foreground="{DynamicResource Brush.SecondaryText}" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
