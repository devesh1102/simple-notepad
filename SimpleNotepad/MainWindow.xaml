<Window x:Class="SimpleNotepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleNotepad"
        mc:Ignorable="d"
        Title="Simple Notepad"
        Height="720"
        Width="1100"
        MinHeight="480"
        MinWidth="760">
    <Grid Background="#F6F7F9">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="220" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" MinWidth="420" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#D7DCE2"
                BorderThickness="0,0,1,0">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Sessions"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#1F2937" />

                <Button x:Name="NewSessionButton"
                        Grid.Row="1"
                        Margin="0,14,0,12"
                        Padding="10,7"
                        HorizontalContentAlignment="Left"
                        Content="+ New Session"
                        Click="NewSessionButton_Click" />

                <TextBox x:Name="SessionSearchBox"
                         Grid.Row="2"
                         Margin="0,0,0,12"
                         Padding="8,6"
                         ToolTip="Search sessions"
                         TextChanged="SessionSearchBox_TextChanged" />

                <ListBox x:Name="SessionsList"
                         Grid.Row="3"
                         BorderThickness="0"
                         Background="Transparent"
                         PreviewMouseRightButtonDown="SessionsList_PreviewMouseRightButtonDown"
                         ContextMenuOpening="SessionsList_ContextMenuOpening"
                         SelectionChanged="SessionsList_SelectionChanged">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Rename" Click="RenameSession_Click" />
                            <MenuItem Header="Delete" Click="DeleteSession_Click" />
                            <Separator />
                            <MenuItem Header="Pin/Unpin" Click="PinSession_Click" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,3,0,0"
                                           Text="{Binding ExpiryText}"
                                           FontSize="12"
                                           Foreground="#6B7280" />
                                <TextBlock Margin="0,3,0,0"
                                           Text="{Binding LastModifiedText}"
                                           FontSize="12"
                                           Foreground="#6B7280" />
                                <TextBlock Margin="0,3,0,0"
                                           Text="{Binding Preview}"
                                           FontSize="12"
                                           Foreground="#6B7280"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      Background="#D7DCE2" />

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="16,12"
                    Background="#FFFFFF"
                    BorderBrush="#D7DCE2"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="True">
                    <TextBox x:Name="SessionTitleBox"
                             Text="Untitled"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalAlignment="Center"
                             TextChanged="SessionTitleBox_TextChanged" />
                    <TextBlock x:Name="SaveStateText"
                               DockPanel.Dock="Right"
                               Text="Saved"
                               Foreground="#059669"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Padding="10"
                    Background="#EEF2F7"
                    BorderBrush="#D7DCE2"
                    BorderThickness="0,0,0,1"
                    Visibility="Collapsed">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="Find"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBox Width="180"
                             Margin="0,0,10,0" />
                    <TextBlock Text="Replace"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBox Width="180"
                             Margin="0,0,10,0" />
                    <Button Content="Prev"
                            Margin="0,0,6,0" />
                    <Button Content="Next"
                            Margin="0,0,6,0" />
                    <Button Content="Replace"
                            Margin="0,0,6,0" />
                    <Button Content="All"
                            Margin="0,0,6,0" />
                    <Button Content="x" />
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="16"
                    Background="#FFFFFF"
                    BorderBrush="#D7DCE2"
                    BorderThickness="1">
                <avalonEdit:TextEditor x:Name="Editor"
                                       ShowLineNumbers="True"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       Padding="8"
                                       WordWrap="True"
                                       TextChanged="Editor_TextChanged" />
            </Border>

            <Border Grid.Row="3"
                    Padding="12,7"
                    Background="#FFFFFF"
                    BorderBrush="#D7DCE2"
                    BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText"
                           Text="Ln 1, Col 1 | 0 chars | Saved"
                           Foreground="#4B5563" />
            </Border>
        </Grid>
    </Grid>
</Window>
